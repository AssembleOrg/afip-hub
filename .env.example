# ============================================
# CONFIGURACIÓN GENERAL
# ============================================

# Puerto del servidor
PORT=3000

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# URL pública donde corre la API — se usa en back_url de MercadoPago y webhooks.
PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# BASE DE DATOS
# ============================================

# URL de conexión a la base de datos PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/database
DATABASE_URL=postgresql://user:password@localhost:5432/afip_hub

# ============================================
# REDIS (opcional)
# ============================================
# Sin REDIS_URL la app funciona degradada (rate-limit en memoria por instancia,
# ticket WSAA solo local). Con Redis, compartido entre réplicas.
# Formato: redis://[:password@]host:port[/db]
# REDIS_URL=redis://localhost:6379

# ============================================
# HASHICORP VAULT (requerido para certificados + scheduled tasks)
# ============================================
# Sin VAULT_ADDR, los endpoints /certificates y /scheduled-tasks tiran 503.
# El flujo inline cert-per-request del resto de /afip/* sigue funcionando.
# VAULT_ADDR=https://vault.tu-proyecto.up.railway.app
# VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxx
# VAULT_KV_MOUNT=secret
# VAULT_BASE_PATH=afip-hub
# VAULT_NAMESPACE=            # solo si usás Vault Enterprise con namespaces

# ============================================
# MÉTRICAS Prometheus
# ============================================
# Token opcional para proteger GET /metrics (Authorization: Bearer <token>).
# Sin seteo, /metrics queda abierto (dev). En prod: obligatorio.
# METRICS_TOKEN=<generar: openssl rand -hex 32>

# ============================================
# DIGITALOCEAN SPACES (archivo frío de invoices viejas)
# ============================================
# Sin SPACES_* el retention cron igual corre, pero no puede mover los
# rawRequest/rawResponse de invoices — quedan en Postgres ocupando volumen.
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_REGION=us-east-1                 # DO lo ignora, la SDK lo pide
# SPACES_BUCKET=afip-hub-archives
# SPACES_KEY=DO00xxxxxxxxxx
# SPACES_SECRET=xxxxxxxxxxxxxxxxxxxx
# SPACES_PREFIX=afip-hub                  # todo bajo <prefix>/orgs/{orgId}/invoices/<id>.json

# ============================================
# RETENTION (purge + archival)
# ============================================
# Días que se conservan antes de purgar/archivar. Default conservador.
# RETENTION_USAGE_EVENTS_DAYS=90
# RETENTION_WEBHOOK_OK_DAYS=30
# RETENTION_WEBHOOK_FAIL_DAYS=90
# RETENTION_NOTIFICATIONS_DAYS=90
# RETENTION_TASK_RUNS_DAYS=90
# RETENTION_EXCHANGE_DAYS=7
# RETENTION_INVOICE_ARCHIVE_DAYS=180      # tras esto, invoices se mueven a DO Spaces
# RETENTION_AUDIT_DAYS=395                # 13 meses

# ============================================
# ALERTAS DE VOLUMEN (Postgres)
# ============================================
# Tamaño total del volumen Railway en bytes (default 50GB = 53687091200).
# STORAGE_VOLUME_BYTES=53687091200
# Lista de umbrales % que disparan email al platform admin (máximo 1 mail/día por nivel).
# STORAGE_ALERT_THRESHOLDS=60,80,90

# ============================================
# MERCADOPAGO (billing)
# ============================================
# Access token "user token" de la cuenta que cobra (PROD o SANDBOX)
# Se saca de https://www.mercadopago.com.ar/developers/panel
# MP_ACCESS_TOKEN=APP_USR-...

# Secreto para verificar firma HMAC de webhooks (recomendado en prod)
# MP_WEBHOOK_SECRET=...

# URL a la que MP redirige al user tras autorizar el preapproval
# MP_BACK_SUCCESS_URL=https://tu-dashboard.com/billing/success
# MP_BACK_FAILURE_URL=https://tu-dashboard.com/billing/failure

# Frecuencia de cobro (default: 1 months)
# MP_FREQUENCY=1
# MP_FREQUENCY_TYPE=months

# ============================================
# EXCHANGE RATE (dólar blue)
# ============================================
# Fuente para la cotización — por default dolarapi.com blue.
# EXCHANGE_RATE_SOURCE=https://dolarapi.com/v1/dolares/blue

# Cron del refresco (default cada 15 minutos)
# EXCHANGE_RATE_CRON=0 */15 * * * *

# ============================================
# OBSERVABILIDAD
# ============================================
# DSN de Sentry (opcional). Si vacío, Sentry no se inicializa.
# SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# OPENTELEMETRY tracing (opcional)
# ============================================
# Endpoint OTLP/HTTP: Grafana Tempo, Jaeger, Honeycomb, SigNoz, etc.
# Sin este env el tracing no arranca y la app funciona igual.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana-agent.railway.internal:4318
# OTEL_SERVICE_NAME=afip-hub
# OTEL_TRACES_ENABLED=true                  # set a false para deshabilitar
# OTEL_EXPORTER_OTLP_HEADERS=x-api-key=xxx  # si el endpoint requiere auth

# ============================================
# CORS (obligatorio en producción)
# ============================================
# Lista de orígenes permitidos, separados por coma. NO usar * en prod.
# CORS_ORIGINS=https://dashboard.afip-hub.com,https://app.afip-hub.com

# ============================================
# EMAIL (transaccional)
# ============================================
# Proveedor: brevo | smtp | console (console = solo loguea en dev)
EMAIL_PROVIDER=brevo

# Sender (común a todos los providers)
EMAIL_FROM_ADDRESS=no-reply@afip-hub.com
EMAIL_FROM_NAME=AFIP Hub
# EMAIL_REPLY_TO=soporte@afip-hub.com

# Brevo (ex-Sendinblue). Key: https://app.brevo.com/settings/keys/api
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx

# SMTP fallback (solo si EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxxxxxxxxx

# ============================================
# BRANDING (aparece en los emails)
# ============================================
BRAND_PRODUCT_NAME=afip·hub
BRAND_PRIMARY_COLOR=#0F766E
BRAND_SUPPORT_EMAIL=soporte@afip-hub.com
BRAND_DASHBOARD_URL=https://app.afip-hub.com
# URL de un PNG transparente ≤40px de alto, para el header del email.
# BRAND_LOGO_URL=https://cdn.tu-dominio.com/logo-email.png

# ============================================
# Tokens de verificación / reset
# ============================================
# VERIFY_EMAIL_TTL_HOURS=48
# VERIFY_EMAIL_REQUIRED_FOR_BILLING=true
# PASSWORD_RESET_TTL_MINUTES=60

# ============================================
# JWT (JSON Web Tokens)
# ============================================

# Secret key para firmar los tokens JWT (cambiar en producción)
JWT_SECRET=your-secret-key-change-in-production

# Tiempo de expiración de los tokens JWT
JWT_EXPIRES_IN=24h

# ============================================
# SWAGGER / DOCUMENTACIÓN API
# ============================================

# Habilitar Swagger UI (true/false)
SWAGGER_ENABLED=true

# Contraseña para acceder a Swagger UI
SWAGGER_PASSWORD=admin

# ============================================
# CONFIGURACIÓN AFIP
# ============================================

# Entorno de AFIP a utilizar
# - homologacion: Entorno de pruebas (default, recomendado para desarrollo)
# - production: Entorno de producción (facturas reales, fiscalmente válidas)
AFIP_ENVIRONMENT=homologacion

# URLs de servicios AFIP (opcionales - se usan valores por defecto según AFIP_ENVIRONMENT)
# Solo configurar si necesitas usar URLs personalizadas

# Web Service de Autenticación y Autorización
# AFIP_WSAA_URL=https://wsaahomo.afip.gov.ar/ws/services/LoginCms?WSDL

# Web Service de Facturación Electrónica
# AFIP_WSFE_URL=https://wswhomo.afip.gov.ar/wsfev1/service.asmx?WSDL

# Web Service de Padrón (Constancia de Inscripción)
# AFIP_PADRON_URL=https://awshomo.afip.gov.ar/sr-padron/webservices/personaServiceA5?WSDL

# Web Service de Ventanilla Electrónica
# AFIP_VENTANILLA_URL=https://stable-middleware-tecno-ext.afip.gob.ar/ve-ws/services/veconsumer?wsdl

# Web Service de Constatación de Comprobantes
# AFIP_WSCDC_URL=https://wswhomo.arca.gov.ar/WSCDC/service.asmx?WSDL

# Persistencia del caché de tickets AFIP (evita "ya posee un TA válido" tras reinicios)
# Si no se define, se usa .afip-ticket-cache.json en el directorio de trabajo.
# En Railway/servidores con disco efímero, usar un volumen persistente, ej: /data/afip-ticket-cache.json
# AFIP_TICKET_CACHE_PATH=/ruta/persistente/.afip-ticket-cache.json

# ============================================
# CERTIFICADOS AFIP (Opcional - Legacy)
# ============================================
# NOTA: En la arquitectura multi-tenant actual, los certificados y claves privadas
# se envían en cada request. Estos campos solo se usan si necesitas mantener
# compatibilidad con código legacy o para pruebas locales.

# Ruta al archivo de certificado (.crt) - Solo si usas archivos locales
# AFIP_CERT_PATH=/path/to/certificate.crt

# Ruta al archivo de clave privada (.key) - Solo si usas archivos locales
# AFIP_KEY_PATH=/path/to/private.key

# CUIT por defecto - Solo si usas configuración legacy
# AFIP_CUIT=20123456789

# ============================================
# CUIT MAESTRO — Padrón A13 (consultas internas sin exponer cert del cliente)
# ============================================
# CUIT del emisor maestro que se usa para consultar el padrón A13 en nombre de todos los clientes.
# El certificado y clave pueden enviarse como texto PEM (con saltos de línea escapados \n) o en base64.
MASTER_PADRON_CUIT=
MASTER_PADRON_CERT=
MASTER_PADRON_KEY=

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# 1. En producción, NUNCA commitees el archivo .env real
# 2. Cambia JWT_SECRET por un valor seguro y aleatorio en producción
# 3. AFIP_ENVIRONMENT=homologacion es el default seguro para desarrollo
# 4. Los certificados y claves privadas ahora se envían en cada request
#    como parte de la arquitectura multi-tenant
# 5. Las URLs de AFIP tienen valores por defecto según el entorno,
#    solo configúralas si necesitas URLs personalizadas
#
# ============================================
# URLs POR DEFECTO SEGÚN ENTORNO
# ============================================
#
# HOMOLOGACIÓN (AFIP_ENVIRONMENT=homologacion):
# - WSAA: https://wsaahomo.afip.gov.ar/ws/services/LoginCms?WSDL
# - WSFE: https://wswhomo.afip.gov.ar/wsfev1/service.asmx?WSDL
# - Padrón: https://awshomo.afip.gov.ar/sr-padron/webservices/personaServiceA5?WSDL
# - Ventanilla: https://stable-middleware-tecno-ext.afip.gob.ar/ve-ws/services/veconsumer?wsdl
# - WSCDC: https://wswhomo.arca.gov.ar/WSCDC/service.asmx?WSDL
#
# PRODUCCIÓN (AFIP_ENVIRONMENT=production):
# - WSAA: https://wsaa.afip.gov.ar/ws/services/LoginCms?WSDL
# - WSFE: https://servicios1.afip.gov.ar/wsfev1/service.asmx?WSDL
# - Padrón: https://aws.afip.gov.ar/sr-padron/webservices/personaServiceA5?WSDL
# - Ventanilla: https://infraestructura.afip.gob.ar/ve-ws/services/veconsumer?wsdl
# - WSCDC: https://servicios1.arca.gov.ar/WSCDC/service.asmx?WSDL
#

ADMIN_EMAIL=admin@afip-hub.com
ADMIN_PASSWORD=Admin123!
SUBADMIN_EMAIL=subadmin@afip-hub.com
SUBADMIN_PASSWORD=Subadmin123!
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
GLOBAL_RATE_LIMIT=300
MP_NOTIFICATION_URL=https://api.tudominio.com/api/billing/webhook
EMAIL_API_KEY=
EMAIL_FROM=no-reply@afip-hub.com
